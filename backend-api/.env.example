# EssayAI Backend Environment Variables
# Copy to .env and fill in your values

GOOGLE_AI_API_KEY=your_gemini_api_key_here
GOOGLE_AI_MODEL=gemini-1.5-flash  # ✅ Works (or gemini-2.0-flash)

# OLD/BROKEN: gemini-2.0-flash-exp → 404 Not Found

# Other vars (if needed)
DATABASE_URL=mongodb://localhost:27017/essayai
CLOUDINARY_URL=your_cloudinary_url
SEPAY_MERCHANT_ID=your_sepay_id

