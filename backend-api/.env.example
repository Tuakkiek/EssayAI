# ── Server ────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────────────────────────
MONGODB_URI=

# ── Google AI Studio (Gemini) ────────────────────────────────────
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash

# ── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_REVIEW_IMAGE_PRESET=
CLOUDINARY_VIDEO_PRESET=
CLOUDINARY_THUMBNAIL_PRESET=
REVIEW_BASE64_GRACE_UNTIL=

# ── Sepay Payments ───────────────────────────────────────────────
SEPAY_API_TOKEN=
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_ID=
SEPAY_ACCOUNT_NAME=
SEPAY_QR_BASE_URL=
SEPAY_PAYMENT_TTL_MINUTES=

# ── JWT Auth ─────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=

# ── App URLs ──────────────────────────────────────────────────────
APP_URL=
WEBHOOK_URL=

# ── CORS (production only — comma-separated) ─────────────────────
# ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com